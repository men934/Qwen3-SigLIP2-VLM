# Stage3 document/OCR/chart domain SFT.

QWEN_PATH=/root/autodl-tmp/hf_models/Qwen3-1.7B
SIGLIP_PATH=/root/autodl-tmp/hf_models/siglip2-so400m-patch14-384
ANNOTATION_PATH=/root/autodl-tmp/hf_datasets/domain_mix/stage3_mix/train.json
VAL_ANNOTATION_PATH=/root/autodl-tmp/hf_datasets/domain_mix/stage3_mix/val.json
STAGE2_PROJECTOR_PATH=/root/autodl-tmp/checkpoints/stage2_lora_150k_r32/step_018000/projector.pt
