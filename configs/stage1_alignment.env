# Stage1 fixed-resolution visual-language alignment.

QWEN_PATH=/root/autodl-tmp/hf_models/Qwen3-1.7B
SIGLIP_PATH=/root/autodl-tmp/hf_models/siglip2-so400m-patch14-384
ANNOTATION_PATH=/root/autodl-tmp/hf_datasets/LLaVA-Pretrain/blip_laion_cc_sbu_558k.json
IMAGE_ROOT=/root/autodl-tmp/hf_datasets/LLaVA-Pretrain
OUTPUT_DIR=/root/autodl-tmp/checkpoints/stage1_align_50k

MAX_SAMPLES=50000
MAX_STEPS=3000
NUM_EPOCHS=1
BATCH_SIZE=2
GRAD_ACCUM=8
MAX_LENGTH=512
IMAGE_SIZE=384

DYNAMIC_RESOLUTION=0
USE_SIGLIP_ABS_POS=1
USE_SIGLIP_QK_2D_ROPE=0

LR=1e-3
VISION_LR=2e-6
WEIGHT_DECAY=0.0
MAX_GRAD_NORM=1.0

SAVE_EVERY=1000
EVAL_EVERY=1000
EVAL_BATCHES=20
TORCH_DTYPE=bfloat16
DEVICE=cuda

