# Stage4 ABO e-commerce online single-update GRPO-style run.

QWEN_PATH=/root/autodl-tmp/hf_models/Qwen3-1.7B
SIGLIP_PATH=/root/autodl-tmp/hf_models/siglip2-so400m-patch14-384
ANNOTATION_PATH=/root/autodl-tmp/hf_datasets/stage4_ecommerce/stage4_abo/sft/train_100k_balanced.json
VAL_ANNOTATION_PATH=/root/autodl-tmp/hf_datasets/stage4_ecommerce/stage4_abo/sft/val.json
INIT_PROJECTOR_PATH=/root/autodl-tmp/checkpoints/stage4_abo_sft_100k_balanced/best/projector.pt
INIT_LORA_PATH=/root/autodl-tmp/checkpoints/stage4_abo_sft_100k_balanced/best/lora_adapter
OUTPUT_DIR=/root/autodl-tmp/checkpoints/stage4_abo_grpo_short_reward_v2

MAX_SAMPLES=100000
MAX_STEPS=3000
NUM_EPOCHS=1
PROMPT_BATCH_SIZE=1
NUM_GENERATIONS=4
MAX_NEW_TOKENS=32
MAX_PROMPT_LENGTH=256
TEMPERATURE=0.7
TOP_P=0.9

LR=5e-6
WEIGHT_DECAY=0.0
MAX_GRAD_NORM=1.0
CLIP_RANGE=0.2
ADVANTAGE_CLIP=5.0
KL_BETA=0.05

TOKEN_F1_REWARD_WEIGHT=0.1
GENERATIVE_F1_REWARD_WEIGHT=1.0
GENERATIVE_EXACT_BONUS=0.1
STYLE_F1_REWARD_WEIGHT=0.25
LENGTH_PENALTY_WEIGHT=0.02
MAX_REWARD_TOKENS=8
GENERATIVE_MAX_REWARD_TOKENS=48
TASK_SAMPLING_WEIGHTS='{"product_style_qa":2.5,"product_title_generation":2.0,"product_attribute_summary":1.5}'

EARLY_STOP_PATIENCE=4
EARLY_STOP_MIN_DELTA=0.002
EARLY_STOP_MIN_STEPS=750
TRAIN_PROJECTOR=0

SAVE_EVERY=0
EVAL_EVERY=250
EVAL_SAMPLES=300
LOG_EVERY=25
TORCH_DTYPE=bfloat16
DEVICE=cuda

